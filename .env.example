NODE_ENV=development
PORT=3000
DB_HOST=localhost
DB_PORT=5433
DB_NAME=backend
DB_SCHEMA=
DB_USER=backend
DB_PASSWORD=backend
DB_LOGGING=false
RABBITMQ_URL=amqp://guest:guest@localhost:5672
RABBITMQ_QUEUE=default
USER_CREATED_QUEUE=user.created
AUTH_EVENTS_QUEUE=auth.events
NOTIFICATION_EVENTS_QUEUE=notification.events
MQ_PREFETCH_COUNT=10
OUTBOX_BATCH_SIZE=20
OUTBOX_POLL_INTERVAL_MS=3000
NOTIFICATION_MAX_DELIVERY_RETRIES=5
AUTH_ACCESS_TOKEN_SECRET=dev-access-secret
AUTH_REFRESH_TOKEN_SECRET=dev-refresh-secret
AUTH_ACCESS_TOKEN_TTL_SECONDS=900
AUTH_REFRESH_TOKEN_TTL_DAYS=30
AUTH_PASSWORD_PEPPER=
LOKI_URL=http://localhost:3100
OTEL_SERVICE_NAME=backend-api
