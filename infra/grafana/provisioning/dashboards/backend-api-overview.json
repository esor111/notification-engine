{
  "dashboard": {
    "title": "Backend API Overview",
    "tags": ["backend", "api", "notifications"],
    "timezone": "browser",
    "schemaVersion": 16,
    "version": 0,
    "refresh": "10s",
    "panels": [
      {
        "id": 1,
        "title": "HTTP Request Rate",
        "type": "graph",
        "gridPos": {"x": 0, "y": 0, "w": 12, "h": 8},
        "targets": [
          {
            "expr": "rate(http_requests_total[5m])",
            "legendFormat": "{{method}} {{route}} - {{status_code}}",
            "refId": "A"
          }
        ]
      },
      {
        "id": 2,
        "title": "HTTP Request Duration (p95)",
        "type": "graph",
        "gridPos": {"x": 12, "y": 0, "w": 12, "h": 8},
        "targets": [
          {
            "expr": "histogram_quantile(0.95, rate(http_request_duration_seconds_bucket[5m]))",
            "legendFormat": "{{method}} {{route}}",
            "refId": "A"
          }
        ]
      },
      {
        "id": 3,
        "title": "Auth Attempts",
        "type": "graph",
        "gridPos": {"x": 0, "y": 8, "w": 12, "h": 8},
        "targets": [
          {
            "expr": "rate(auth_attempts_total[5m])",
            "legendFormat": "{{type}} - {{status}}",
            "refId": "A"
          }
        ]
      },
      {
        "id": 4,
        "title": "Notifications Created",
        "type": "graph",
        "gridPos": {"x": 12, "y": 8, "w": 12, "h": 8},
        "targets": [
          {
            "expr": "rate(notifications_created_total[5m])",
            "legendFormat": "{{event_type}} - {{priority}}",
            "refId": "A"
          }
        ]
      },
      {
        "id": 5,
        "title": "Notification Dispatch Status",
        "type": "graph",
        "gridPos": {"x": 0, "y": 16, "w": 12, "h": 8},
        "targets": [
          {
            "expr": "rate(notifications_dispatched_total[5m])",
            "legendFormat": "{{channel}} - {{status}}",
            "refId": "A"
          }
        ]
      },
      {
        "id": 6,
        "title": "Notification Delivery Duration (p95)",
        "type": "graph",
        "gridPos": {"x": 12, "y": 16, "w": 12, "h": 8},
        "targets": [
          {
            "expr": "histogram_quantile(0.95, rate(notification_delivery_duration_seconds_bucket[5m]))",
            "legendFormat": "{{channel}} - {{provider}}",
            "refId": "A"
          }
        ]
      },
      {
        "id": 7,
        "title": "RabbitMQ Messages Published",
        "type": "graph",
        "gridPos": {"x": 0, "y": 24, "w": 12, "h": 8},
        "targets": [
          {
            "expr": "rate(mq_messages_published_total[5m])",
            "legendFormat": "{{queue}} - {{event_type}}",
            "refId": "A"
          }
        ]
      },
      {
        "id": 8,
        "title": "RabbitMQ Messages Consumed",
        "type": "graph",
        "gridPos": {"x": 12, "y": 24, "w": 12, "h": 8},
        "targets": [
          {
            "expr": "rate(mq_messages_consumed_total[5m])",
            "legendFormat": "{{queue}} - {{status}}",
            "refId": "A"
          }
        ]
      },
      {
        "id": 9,
        "title": "Outbox Events Processed",
        "type": "graph",
        "gridPos": {"x": 0, "y": 32, "w": 12, "h": 8},
        "targets": [
          {
            "expr": "rate(outbox_events_processed_total[5m])",
            "legendFormat": "{{status}}",
            "refId": "A"
          }
        ]
      },
      {
        "id": 10,
        "title": "Application Logs",
        "type": "logs",
        "gridPos": {"x": 12, "y": 32, "w": 12, "h": 8},
        "targets": [
          {
            "expr": "{service=\"backend-api\"}",
            "refId": "A"
          }
        ],
        "options": {
          "showTime": true,
          "showLabels": false,
          "showCommonLabels": false,
          "wrapLogMessage": true,
          "sortOrder": "Descending"
        }
      }
    ]
  }
}
