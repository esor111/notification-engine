{
  "name": "backend-agent-friendly",
  "version": "0.1.0",
  "private": true,
  "description": "Agent-friendly NestJS backend starter",
  "engines": {
    "node": ">=22 <26",
    "npm": ">=11"
  },
  "scripts": {
    "build": "nest build",
    "start": "node dist/main",
    "start:dev": "nest start --watch",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"test/**/*.ts\"",
    "lint": "eslint \"{src,test}/**/*.ts\"",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "jest --runInBand",
    "test:unit": "jest --runInBand --config ./test/jest.unit.config.ts",
    "test:integration": "jest --runInBand --config ./test/jest.integration.config.ts",
    "test:e2e": "jest --runInBand --config ./test/jest.e2e.config.ts",
    "test:contract": "jest --runInBand --config ./test/jest.contract.config.ts",
    "test:smoke": "powershell -ExecutionPolicy Bypass -File ./scripts/smoke.ps1",
    "doctor": "powershell -ExecutionPolicy Bypass -File ./scripts/doctor.ps1",
    "verify": "npm run format:check && npm run lint && npm run typecheck && npm run test:unit && npm run test:integration && npm run test:e2e && npm run test:contract && npm run build",
    "db:migrate": "typeorm-ts-node-commonjs migration:run -d ./typeorm.datasource.ts",
    "db:revert": "typeorm-ts-node-commonjs migration:revert -d ./typeorm.datasource.ts",
    "db:generate": "typeorm-ts-node-commonjs migration:generate ./src/common/db/migrations/AutoMigration -d ./typeorm.datasource.ts"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.0",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.0",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/microservices": "^11.1.0",
    "@nestjs/platform-express": "^11.1.0",
    "@nestjs/swagger": "^11.2.0",
    "@nestjs/typeorm": "^11.0.0",
    "amqplib": "^0.10.5",
    "argon2": "^0.44.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "pg": "^8.16.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "swagger-ui-express": "^5.0.1",
    "typeorm": "^0.3.26"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.7",
    "@nestjs/testing": "^11.1.0",
    "@types/amqplib": "^0.10.7",
    "@types/express": "^5.0.3",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.3.5",
    "@types/supertest": "^6.0.3",
    "@typescript-eslint/eslint-plugin": "^8.40.0",
    "@typescript-eslint/parser": "^8.40.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.8",
    "jest": "^30.0.5",
    "prettier": "^3.6.2",
    "supertest": "^7.1.4",
    "ts-jest": "^29.4.1",
    "ts-node": "^10.9.2",
    "typeorm-ts-node-commonjs": "^0.3.20",
    "typescript": "^5.9.2"
  },
  "packageManager": "npm@11.6.2"
}
